# Database
DATABASE_URL=sqlite:///./get_zen.db

# Logging
LOG_LEVEL=INFO

# Scraper
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3
SCRAPER_LOOKBACK_DAYS=30

# OpenAI / LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_NARRATIVE_MODEL=gpt-4o-mini
OPENAI_PREMIUM_MODEL=gpt-5.2
ANALYSIS_MIN_RELEVANCE=5
LLM_CALL_BUDGET_PER_RUN=200
LLM_INPUT_PRICE_PER_MTOK=2.50
LLM_OUTPUT_PRICE_PER_MTOK=10.00
LLM_PREMIUM_INPUT_PRICE_PER_MTOK=5.00
LLM_PREMIUM_OUTPUT_PRICE_PER_MTOK=15.00

# Blog briefings (daily)
BLOG_GEN_BUDGET_PER_RUN=10
BLOG_GEN_MIN_RELEVANCE=5
BLOG_GEN_LOOKBACK_DAYS=14
BLOG_GEN_MAX_WORDS=900
GOOGLE_NEWS_DAILY_CAP=40

# Newsletter
NEWSLETTER_PROVIDER=console
NEWSLETTER_FROM_EMAIL=briefing@getzen.cash
NEWSLETTER_API_KEY=
SUBSCRIBER_LIST_PATH=subscribers.json
SEO_EMAIL_PROVIDER=resend
SEO_EMAIL_RECIPIENT=
SEO_EMAIL_SUBJECT=Get ZEN — Daily SEO
RESEND_API_KEY=

# Buttondown
BUTTONDOWN_API_KEY=

# Google reporting (GA4 + Search Console)
GOOGLE_REPORTING_SA_JSON=
GOOGLE_REPORTING_SA_FILE=
GOOGLE_REPORTING_GA4_PROPERTY_ID=
GOOGLE_REPORTING_GSC_SITE_URL=
GOOGLE_REPORTING_GA_LOOKBACK_DAYS=30
GOOGLE_REPORTING_GSC_LOOKBACK_DAYS=90

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_REPORT_BUCKET=reports

# Server
SERVER_PORT=8080

# Admin
ADMIN_TOKEN=

# Site
SITE_URL=https://www.getzen.cash
SITE_NAME=Get ZEN
SITE_OWNER_ORG=Get ZEN
SITE_LOCALE=en_US

# IndexNow
INDEXNOW_KEY=

# Google Indexing API
GOOGLE_INDEXING_SA_JSON=
GOOGLE_INDEXING_SA_FILE=
GOOGLE_INDEXING_LOOKBACK_DAYS=7
GOOGLE_INDEXING_MAX_PER_RUN=50

# Ahrefs
AHREFS_API_KEY=
AHREFS_PROJECT_ID=

# Reddit (nomad forums scraper)
# Reddit blocks generic User-Agents. Use the format Reddit requires:
#   <platform>:<app-id>:<version> (by /u/<reddit-username>)
# Example: REDDIT_USER_AGENT=web:getzen-nomad-intel:v0.1 (by /u/yourhandle)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web:getzen-nomad-intel:v0.1
