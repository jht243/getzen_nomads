{# Inline SVG icon set — Lucide-style minimalist stroke icons.
   Used for topic chips, stats rows, and navigation accents.

   Usage:
     {% from "_icons.html.j2" import topic_icon, ui_icon %}
     {{ topic_icon('internet', size=18) }}
     {{ ui_icon('arrow-right', size=14) }}
#}

{%- macro _svg(paths, size=18, stroke=2) -%}
<svg xmlns="http://www.w3.org/2000/svg" width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="{{ stroke }}" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">{{ paths|safe }}</svg>
{%- endmacro -%}

{%- macro topic_icon(slug, size=18) -%}
  {%- if slug == 'internet' -%}
    {{ _svg('<path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/>', size) }}
  {%- elif slug == 'housing' -%}
    {{ _svg('<path d="M3 9.5L12 3l9 6.5V21a1 1 0 0 1-1 1h-5v-7h-6v7H4a1 1 0 0 1-1-1z"/>', size) }}
  {%- elif slug == 'safety' -%}
    {{ _svg('<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>', size) }}
  {%- elif slug == 'banking' -%}
    {{ _svg('<rect x="3" y="11" width="18" height="10" rx="1"/><path d="M2 11l10-7 10 7"/><line x1="6" y1="15" x2="6" y2="18"/><line x1="10" y1="15" x2="10" y2="18"/><line x1="14" y1="15" x2="14" y2="18"/><line x1="18" y1="15" x2="18" y2="18"/>', size) }}
  {%- elif slug == 'crypto' -%}
    {{ _svg('<circle cx="12" cy="12" r="9"/><path d="M9 8.5h4.5a2.25 2.25 0 0 1 0 4.5H9zm0 4.5h5a2.25 2.25 0 0 1 0 4.5H9z"/><line x1="11" y1="6" x2="11" y2="8.5"/><line x1="11" y1="17.5" x2="11" y2="20"/><line x1="14" y1="6" x2="14" y2="8.5"/><line x1="14" y1="17.5" x2="14" y2="20"/>', size) }}
  {%- elif slug == 'visa' -%}
    {{ _svg('<rect x="4" y="3" width="16" height="18" rx="2"/><circle cx="12" cy="10" r="3"/><path d="M7 17.5c1.5-2 3-3 5-3s3.5 1 5 3"/>', size) }}
  {%- elif slug == 'cost-of-living' -%}
    {{ _svg('<rect x="2" y="6" width="20" height="13" rx="2"/><circle cx="12" cy="12.5" r="2.5"/><path d="M6 6V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v1"/>', size) }}
  {%- elif slug == 'coworking' -%}
    {{ _svg('<rect x="2" y="4" width="20" height="13" rx="2"/><line x1="2" y1="20" x2="22" y2="20"/>', size) }}
  {%- elif slug == 'healthcare' -%}
    {{ _svg('<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>', size) }}
  {%- elif slug == 'logistics' -%}
    {{ _svg('<rect x="1" y="3" width="15" height="13" rx="1"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>', size) }}
  {%- elif slug == 'scam-prevention' -%}
    {{ _svg('<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>', size) }}
  {%- else -%}
    {{ _svg('<circle cx="12" cy="12" r="9"/>', size) }}
  {%- endif -%}
{%- endmacro -%}

{%- macro ui_icon(name, size=16, stroke=2) -%}
  {%- if name == 'arrow-right' -%}
    {{ _svg('<line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>', size, stroke) }}
  {%- elif name == 'map-pin' -%}
    {{ _svg('<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>', size, stroke) }}
  {%- elif name == 'globe' -%}
    {{ _svg('<circle cx="12" cy="12" r="9"/><line x1="3" y1="12" x2="21" y2="12"/><path d="M12 3a14 14 0 0 1 4 9 14 14 0 0 1-4 9 14 14 0 0 1-4-9 14 14 0 0 1 4-9z"/>', size, stroke) }}
  {%- elif name == 'check' -%}
    {{ _svg('<polyline points="20 6 9 17 4 12"/>', size, stroke) }}
  {%- elif name == 'calendar' -%}
    {{ _svg('<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>', size, stroke) }}
  {%- elif name == 'building' -%}
    {{ _svg('<rect x="4" y="2" width="16" height="20" rx="1"/><line x1="9" y1="6" x2="9" y2="6.01"/><line x1="15" y1="6" x2="15" y2="6.01"/><line x1="9" y1="10" x2="9" y2="10.01"/><line x1="15" y1="10" x2="15" y2="10.01"/><line x1="9" y1="14" x2="9" y2="14.01"/><line x1="15" y1="14" x2="15" y2="14.01"/><line x1="9" y1="18" x2="15" y2="18"/>', size, stroke) }}
  {%- else -%}
    {{ _svg('<circle cx="12" cy="12" r="9"/>', size, stroke) }}
  {%- endif -%}
{%- endmacro -%}
